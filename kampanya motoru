add_filter('woocommerce_package_rates', 'tb_v4_secure_shipping', 100, 2);
function tb_v4_secure_shipping($rates, $package) {
    if (!is_user_logged_in()) return $rates;
    $user = wp_get_current_user();
    $data = get_option('tb_engine_v4_settings', array());
    
    $allowed_methods = array(); 
    $has_restriction = false;

    foreach((array)$user->roles as $r) {
        if (isset($data['roles_config'][$r]['shipping']) && !empty($data['roles_config'][$r]['shipping'])) {
            $allowed_methods = array_merge($allowed_methods, $data['roles_config'][$r]['shipping']);
            $has_restriction = true;
        }
    }

    if (!$has_restriction) return $rates;

    foreach ($rates as $id => $rate) {
        $is_allowed = false;
        foreach($allowed_methods as $allowed_id) {
            if (strpos($id, $allowed_id) !== false) {
                $is_allowed = true;
                break;
            }
        }
        if (!$is_allowed) unset($rates[$id]);
    }
    return $rates;
}

add_filter('woocommerce_available_payment_gateways', 'tb_v4_secure_payment');
function tb_v4_secure_payment($gateways) {
    if (!is_user_logged_in() || is_admin()) return $gateways;
    $user = wp_get_current_user();
    $data = get_option('tb_engine_v4_settings', array());
    
    $allowed_gateways = array();
    $has_restriction = false;

    foreach((array)$user->roles as $r) {
        if (isset($data['roles_config'][$r]['payment']) && !empty($data['roles_config'][$r]['payment'])) {
            $allowed_gateways = array_merge($allowed_gateways, $data['roles_config'][$r]['payment']);
            $has_restriction = true;
        }
    }

    if (!$has_restriction) return $gateways;

    foreach ($gateways as $id => $gateway) {
        if (!in_array($id, $allowed_gateways)) unset($gateways[$id]);
    }
    return $gateways;
}

add_filter('woocommerce_coupon_is_valid', 'tb_v4_secure_coupon', 10, 2);
function tb_v4_secure_coupon($valid, $coupon) {
    if (!is_user_logged_in()) return $valid;
    $user = wp_get_current_user();
    $data = get_option('tb_engine_v4_settings', array());
    
    foreach((array)$user->roles as $r) {
        // Eğer rolde kupon izni kapalıysa geçersiz say
        if (isset($data['roles_config'][$r]) && empty($data['roles_config'][$r]['allow_coupon'])) {
            return false;
        }
    }
    return $valid;
}
