add_action('woocommerce_process_product_meta', 'tb_v4_save_product_secure');
function tb_v4_save_product_secure($post_id) {
    if (!current_user_can('edit_products')) return; // Yetki Kontrolü

    global $wp_roles;
    foreach ($wp_roles->roles as $key => $info) {
        if (isset($_POST['_tb_price_' . $key])) {
            $price_val = sanitize_text_field($_POST['_tb_price_' . $key]);
            $price_val = str_replace(',', '.', $price_val); // Virgülü noktaya çevir
            
            if ($price_val === '') {
                delete_post_meta($post_id, '_tb_price_' . $key);
            } else {
                update_post_meta($post_id, '_tb_price_' . $key, esc_attr($price_val));
            }
        }
    }
}

