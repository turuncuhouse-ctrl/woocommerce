/* ==========================================================================
   4. FİYAT MOTORU (STABİL)
   ========================================================================== */
add_filter('woocommerce_product_get_price', 'tb_v4_price_engine', 99, 2);
add_filter('woocommerce_product_variation_get_price', 'tb_v4_price_engine', 99, 2);

function tb_v4_price_engine($price, $product) {
    if (is_admin() && !defined('DOING_AJAX')) return $price;
    if (!is_user_logged_in()) return $price;

    $user = wp_get_current_user();
    $data = get_option('tb_engine_v4_settings', array());
    $best_price = $price; 
    $found = false;

    foreach ((array)$user->roles as $role) {
        // 1. Net Fiyat Kontrolü
        $net_price = get_post_meta($product->get_id(), '_tb_price_' . $role, true);
        if (!empty($net_price) && is_numeric($net_price)) {
            if ($net_price < $best_price) { 
                $best_price = $net_price; 
                $found = true; 
            }
            continue; // Net fiyat varsa indirim hesaplama
        }

        // 2. Kategori İndirimi Kontrolü
        if (isset($data['roles_config'][$role]['cat_disc'])) {
            $discs = $data['roles_config'][$role]['cat_disc'];
            foreach ($product->get_category_ids() as $cid) {
                if (!empty($discs[$cid]) && $discs[$cid] > 0) {
                    $discounted = $price - ($price * (floatval($discs[$cid]) / 100));
                    if ($discounted < $best_price) {
                        $best_price = $discounted;
                        $found = true;
                    }
                }
            }
        }
    }
    return $found ? $best_price : $price;
}

