add_action('init', 'tb_v4_secure_init');
function tb_v4_secure_init() {
    if (!get_option('tb_dropshipper_installed')) {
        if (!get_role('dropshipper')) {
            add_role('dropshipper', 'Dropshipper', array('read' => true, 'edit_posts' => false));
