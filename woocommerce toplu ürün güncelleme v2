    <script type="text/javascript">
    jQuery(document).ready(function($) {
        $('.kategori-select').select2({ placeholder: "Kategorileri seçin..." });

        function gosterBildirim(mesaj, renk = '#4caf50') {
            $('.ozel-toast').remove();
            var toast = $('<div class="ozel-toast" style="position:fixed; bottom:30px; right:30px; background:'+renk+'; color:#fff; padding:12px 20px; border-radius:4px; box-shadow:0 4px 10px rgba(0,0,0,0.2); z-index:9999;">'+mesaj+'</div>');
            $('body').append(toast);
            setTimeout(function() { toast.fadeOut(function(){ $(this).remove(); }); }, 2500);
        }

        $('.otomatik-kaydet-input').on('change', function() {
            var el = $(this);
            $.post(ajaxurl, { action: 'oto_kayit_islem', id: el.data('id'), tur: el.data('tur'), deger: el.val() }, function(res) { 
                gosterBildirim('✅ ' + res.data); 
            });
        });

        $('.btn-sku-olustur').on('click', function(e) {
            e.preventDefault();
            var d = new Date();
            var saat = String(d.getHours()).padStart(2, '0');
            var dk = String(d.getMinutes()).padStart(2, '0');
            var gun = String(d.getDate()).padStart(2, '0');
            var ay = String(d.getMonth() + 1).padStart(2, '0');
            var yil = String(d.getFullYear()).slice(-2); 
            var yeni_sku = 'TB' + saat + dk + gun + ay + yil;
            $('.sku-input-' + $(this).data('id')).val(yeni_sku).trigger('change');
        });

        // Ana görsel düzenlemesi resim eklememe sorunu giderildi
        $('.resim-secici').on('click', function(e) {
            e.preventDefault(); 
            var img = $(this);
            var id = img.data('id');

            var custom_uploader = wp.media({
                title: 'Ana Görsel Seç',
                button: { text: 'Görseli Kullan' },
                multiple: false
            });

            custom_uploader.on('select', function() {
                var attachment = custom_uploader.state().get('selection').first().toJSON();
                // Ekranda görseli hemen değiştir
                var imageUrl = (attachment.sizes && attachment.sizes.thumbnail) ? attachment.sizes.thumbnail.url : attachment.url;
                img.attr('src', imageUrl);
                
                // Arka planda kaydet
                $.post(ajaxurl, { action:'oto_kayit_islem', id:id, tur:'ana_resim', deger:attachment.id }, function(res){ 
                    gosterBildirim('✅ ' + res.data); 
                });
            });

            custom_uploader.open();
        });

        // Galeri resimlerini güncelleme sorun giderildi
        $('.galeri-secici').on('click', function(e) {
            e.preventDefault(); 
            var btn = $(this); 
            var id = btn.data('id');

            var galeri_uploader = wp.media({
                title: 'Galeri Görselleri (Çoklu Seçim Yapabilirsiniz)',
                button: { text: 'Galeriye Ekle' },
                multiple: true
            });

            galeri_uploader.on('select', function() {
                var selection = galeri_uploader.state().get('selection');
                var ids = []; 
                var html = '';
                
                selection.map(function(attachment) {
                    var att = attachment.toJSON();
                    ids.push(att.id);
                    var img_url = (att.sizes && att.sizes.thumbnail) ? att.sizes.thumbnail.url : att.url;
                    html += '<img src="'+img_url+'" style="width:30px; height:30px; object-fit:cover; margin-right:2px; border-radius:3px;">';
                });
                
                // Ekranda galeri kutusunu hemen güncelle
                $('#galeri-kutusu-' + id).html(html);
                
                // Arka planda kaydet
                $.post(ajaxurl, { action:'oto_kayit_islem', id:id, tur:'galeri', deger:ids.join(',') }, function(res){ 
                    gosterBildirim('✅ ' + res.data); 
                });
            });

            galeri_uploader.open();
        });

        function topluIslemGonder(islem_turu, veriler) {
            var ids = []; $('.urun-satiri').each(function() { ids.push($(this).data('id')); });
            if(ids.length === 0) return;
            gosterBildirim('⏳ İşlem yapılıyor...', '#2271b1');
            veriler.action = 'oto_toplu_islem'; veriler.ids = ids; veriler.islem = islem_turu;
            $.post(ajaxurl, veriler, function(res) {
                gosterBildirim('✅ ' + res.data);
                setTimeout(function(){ location.reload(); }, 1500); 
            });
        }

        $('#btn_toplu_fiyat').click(function() {
            var deger = $('#toplu_fiyat_deger').val();
            if(!deger) return;
            if(confirm("Tüm fiyatlar güncellenecek. Emin misiniz?")) {
                topluIslemGonder('fiyat', { tur: $('#toplu_fiyat_tur').val(), yon: $('#toplu_fiyat_yon').val(), deger: deger });
            }
        });

        $('#btn_toplu_not').click(function() {
            if(confirm("Özel not tüm ürünlere yazılacak. Emin misiniz?")) {
                topluIslemGonder('not', { metin: $('#toplu_not_deger').val() });
            }
        });
    });
    </script>
    <style> .select2-container .select2-selection--multiple { min-height: 40px; } </style>
