// 4. arka plan kayıt işlemleri
add_action('wp_ajax_oto_kayit_islem', 'ajax_oto_kayit_islem');
function ajax_oto_kayit_islem() {
    $urun = wc_get_product(intval($_POST['id']));
    if (!$urun) wp_send_json_error('Hata!');
    $tur = $_POST['tur']; $deger = $_POST['deger']; $msg = "Güncellendi.";

    if ($tur === 'isim') { $urun->set_name(sanitize_text_field($deger)); $msg = "İsim kaydedildi."; }
    if ($tur === 'sku') { $urun->set_sku(sanitize_text_field($deger)); $msg = "SKU kaydedildi."; }
    if ($tur === 'fiyat') { $urun->set_regular_price(sanitize_text_field($deger)); $msg = "Fiyat kaydedildi."; }
    if ($tur === 'kategori') { $urun->set_category_ids(!empty($deger) ? array_map('intval', $deger) : array()); $msg = "Kategori kaydedildi."; }
    if ($tur === 'ana_resim') { $urun->set_image_id(intval($deger)); $msg = "Görsel kaydedildi."; }
    if ($tur === 'galeri') { $urun->set_gallery_image_ids(!empty($deger) ? explode(',', $deger) : array()); $msg = "Galeri kaydedildi."; }
    if ($tur === 'not') { $urun->update_meta_data('_ozel_kargo_notu', sanitize_textarea_field($deger)); $msg = "Not kaydedildi."; }
    if ($tur === 'etiket') { wp_set_object_terms($urun->get_id(), array_map('trim', explode(',', $deger)), 'product_tag'); $msg = "Etiket kaydedildi."; }
    if ($tur === 'stok') { 
        if($deger === '') { $urun->set_manage_stock(false); } 
        else { $urun->set_manage_stock(true); $urun->set_stock_quantity(intval($deger)); }
        $msg = "Stok kaydedildi."; 
    }

    $urun->save(); wp_send_json_success($msg);
}

add_action('wp_ajax_oto_toplu_islem', 'ajax_oto_toplu_islem');
function ajax_oto_toplu_islem() {
    $ids = isset($_POST['ids']) ? $_POST['ids'] : array();
    $islem = $_POST['islem'];

    foreach ($ids as $id) {
        $urun = wc_get_product($id); if(!$urun) continue;
        if ($islem === 'fiyat') {
            $mevcut = (float) $urun->get_regular_price();
            $tur = $_POST['tur']; $yon = $_POST['yon']; $deger = (float) $_POST['deger'];
            $fark = ($tur === 'yuzde') ? ($mevcut * ($deger / 100)) : $deger;
            $yeni = ($yon === 'artir') ? ($mevcut + $fark) : ($mevcut - $fark);
            $urun->set_regular_price(round($yeni, 2));
        }
        if ($islem === 'not') { $urun->update_meta_data('_ozel_kargo_notu', sanitize_text_field($_POST['metin'])); }
        $urun->save();
    }
    wp_send_json_success("Tüm işlemler başarıyla tamamlandı!");
}
