function na_page_sender_master() {
    if ( ! current_user_can( 'manage_options' ) ) wp_die('Yetkisiz erişim.');
    global $wpdb;
    $table = $wpdb->prefix . 'na_queue_master';
    $subs_table = $wpdb->prefix . 'na_subs_master';

    if (isset($_GET['remove_queue_id'])) {
        check_admin_referer('na_remove_item');
        $wpdb->delete($table, array('id' => intval($_GET['remove_queue_id'])));
        echo '<div class="updated"><p>Mail kuyruktan çıkartıldı.</p></div>';
    }

    if (isset($_GET['clear_queue'])) {
        check_admin_referer('na_clear_all');
        $wpdb->query("TRUNCATE TABLE $table");
        if (function_exists('as_unschedule_all_actions')) as_unschedule_all_actions('na_process_mail_action');
        echo '<div class="updated"><p>🛑 Kuyruk temizlendi.</p></div>';
    }

    if (isset($_POST['na_start_campaign'])) {
        check_admin_referer('na_start_action', 'na_campaign_nonce');
        
        $subject = sanitize_text_field(wp_unslash($_POST['m_subject']));
        $body = wp_kses_post(wp_unslash($_POST['m_body'])); 
        $target_list = sanitize_text_field($_POST['target_list']); 
        
        $subs = $wpdb->get_results($wpdb->prepare("SELECT email FROM $subs_table WHERE status='active' AND list_type=%s", $target_list));
        $wpdb->query("TRUNCATE TABLE $table");
        update_option('na_campaign_notified', 0);

        foreach($subs as $s) {
            $wpdb->insert($table, array('target_email' => $s->email, 'subject' => $subject, 'content' => $body, 'status' => 'pending'));
        }

        as_schedule_single_action( time(), 'na_process_mail_action', array(), 'na_newsletter_group' );
        echo '<div class="updated"><p>🚀 Kampanya güvenli bir şekilde başlatıldı!</p></div>';
    }

    $total_queue = (int)$wpdb->get_var("SELECT COUNT(*) FROM $table");
    $pending = (int)$wpdb->get_var("SELECT COUNT(*) FROM $table WHERE status='pending'");
    $completed = $total_queue - $pending;
    $percent = ($total_queue > 0) ? round(($completed / $total_queue) * 100) : 0;
    
    $last_sent = $wpdb->get_results("SELECT * FROM $table WHERE status='sent' ORDER BY id DESC LIMIT 5");
    $next_pending = $wpdb->get_results("SELECT * FROM $table WHERE status='pending' ORDER BY id ASC LIMIT 5");
    ?>
    <div class="wrap">
        <h1>📧 Mail Gönderim Merkezi</h1>
        <div style="display:grid; grid-template-columns: 2fr 1fr; gap:20px;">
            <div style="background:#fff; padding:20px; border:1px solid #ccd0d4; border-radius:5px;">
                <form method="post">
                    <?php wp_nonce_field('na_start_action', 'na_campaign_nonce'); ?>
                    <p><strong>Hedef Liste:</strong><br><select name="target_list"><option value="main">Ana Liste</option><option value="test">Test Listesi</option></select></p>
                    <p><strong>Konu:</strong><br><input type="text" name="m_subject" class="large-text" required></p>
                    <?php wp_editor('', 'm_body', array('textarea_rows'=>12)); ?>
                    <p><?php submit_button('Kampanyayı Başlat', 'primary', 'na_start_campaign', false); ?></p>
                </form>
            </div>
            <div style="background:#f9f9f9; padding:20px; border:1px solid #ccd0d4; border-radius:5px;">
                <h3>📊 Durum: %<?php echo $percent; ?></h3>
                <div style="background:#e0e0e0; border-radius:10px; height:20px; overflow:hidden;"><div style="background:#4caf50; width:<?php echo $percent; ?>%; height:100%;"></div></div>
                <p><strong><?php echo $completed; ?> / <?php echo $total_queue; ?></strong> gönderildi.</p>
                <?php if($pending > 0): ?>
                    <a href="<?php echo wp_nonce_url('?page=na-sender-master&clear_queue=1', 'na_clear_all'); ?>" class="button" style="color:red; border:1px solid red; width:100%; text-align:center;">⚠️ Kuyruğu Temizle</a>
                <?php endif; ?>
                <hr>
                <h4>✅ Son Gönderilen 5</h4>
                <ul style="font-size:12px; list-style:none; padding:0;">
                    <?php if($last_sent) foreach($last_sent as $ls): echo "<li style='color:green;'>✅ ".esc_html($ls->target_email)."</li>"; endforeach; ?>
                </ul>
                <h4>⏳ Sırada Bekleyen 5</h4>
                <ul style="font-size:12px; list-style:none; padding:0;">
                    <?php if($next_pending) foreach($next_pending as $np): ?>
                        <li style="display:flex; justify-content:space-between; border-bottom:1px solid #eee; padding:4px 0;">
                            <span>⏳ <?php echo esc_html($np->target_email); ?></span>
                            <a href="<?php echo wp_nonce_url('?page=na-sender-master&remove_queue_id='.$np->id, 'na_remove_item'); ?>" style="color:red;">✖</a>
                        </li>
                    <?php endforeach; ?>
                </ul>
            </div>
        </div>
    </div>
    <?php
}

