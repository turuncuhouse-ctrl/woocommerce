add_action('admin_init', 'na_master_engine_install');
function na_master_engine_install() {
    global $wpdb;
    $charset_collate = $wpdb->get_charset_collate();
    require_once(ABSPATH . 'wp-admin/includes/upgrade.php');

    $table_subs = $wpdb->prefix . 'na_subs_master';
    if ($wpdb->get_var("SHOW TABLES LIKE '$table_subs'") != $table_subs) {
        $sql1 = "CREATE TABLE $table_subs (
            id bigint(20) NOT NULL AUTO_INCREMENT,
            email varchar(100) NOT NULL,
            phone varchar(20) DEFAULT '',
            list_type varchar(20) DEFAULT 'main',
            status varchar(20) DEFAULT 'active',
            created_at datetime DEFAULT CURRENT_TIMESTAMP NOT NULL,
            PRIMARY KEY  (id),
            UNIQUE KEY email (email)
        ) $charset_collate;";
        dbDelta($sql1);
    }

    $table_q = $wpdb->prefix . 'na_queue_master';
    if ($wpdb->get_var("SHOW TABLES LIKE '$table_q'") != $table_q) {
        $sql2 = "CREATE TABLE $table_q (
            id bigint(20) NOT NULL AUTO_INCREMENT,
            target_email varchar(100) NOT NULL,
            subject text NOT NULL,
            content longtext NOT NULL,
            status varchar(20) DEFAULT 'pending',
            PRIMARY KEY  (id),
            KEY status_idx (status)
        ) $charset_collate;";
        dbDelta($sql2);
    }
}

