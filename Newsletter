function na_page_subscribers_master() {
    if ( ! current_user_can( 'manage_options' ) ) wp_die('Yetkisiz erişim.');
    global $wpdb;
    $table = $wpdb->prefix . 'na_subs_master';

    if (isset($_GET['delete_sub'])) {
        check_admin_referer('na_delete_sub_' . $_GET['delete_sub']);
        $wpdb->delete($table, array('id' => intval($_GET['delete_sub'])));
        echo '<div class="updated"><p>Abone silindi.</p></div>';
    }

    if (isset($_POST['bulk_delete_action'])) {
        check_admin_referer('na_bulk_subs', 'na_bulk_nonce');
        if(!empty($_POST['sub_ids'])) {
            $ids = array_map('intval', $_POST['sub_ids']);
            $wpdb->query("DELETE FROM $table WHERE id IN (" . implode(',', $ids) . ")");
            echo '<div class="updated"><p>Seçilenler silindi.</p></div>';
        }
    }

    if (isset($_POST['na_import_emails'])) {
        check_admin_referer('na_import_action', 'na_import_nonce');
        $raw_emails = explode("\n", $_POST['import_data']);
        $list_type = sanitize_text_field($_POST['import_list_type']);
        foreach($raw_emails as $e) {
            $e = sanitize_email(trim($e));
            if (is_email($e)) $wpdb->replace($table, array('email' => $e, 'list_type' => $list_type, 'status' => 'active'));
        }
        echo "<div class='updated'><p>Liste güncellendi.</p></div>";
    }

    $subs = $wpdb->get_results("SELECT * FROM $table ORDER BY id DESC LIMIT 500");
    ?>
    <div class="wrap">
        <h1>📢 Abone Yönetimi</h1>
        <div style="background:#fff; padding:15px; border:1px solid #ccd0d4; margin-bottom:20px;">
            <form method="post">
                <?php wp_nonce_field('na_import_action', 'na_import_nonce'); ?>
                <textarea name="import_data" rows="3" style="width:100%;" placeholder="E-postaları yapıştırın..."></textarea><br>
                <select name="import_list_type"><option value="main">Ana Liste</option><option value="test">Test Listesi</option></select>
                <button type="submit" name="na_import_emails" class="button">İçe Aktar</button>
            </form>
        </div>
        <form method="post">
            <?php wp_nonce_field('na_bulk_subs', 'na_bulk_nonce'); ?>
            <table class="wp-list-table widefat fixed striped">
                <thead><tr><th style="width:30px;"><input type="checkbox"></th><th>Email</th><th>Liste</th><th>İşlem</th></tr></thead>
                <tbody>
                    <?php if($subs) foreach($subs as $s): ?>
                    <tr>
                        <td><input type="checkbox" name="sub_ids[]" value="<?php echo $s->id; ?>"></td>
                        <td><?php echo esc_html($s->email); ?></td>
                        <td><?php echo esc_html($s->list_type); ?></td>
                        <td><a href="<?php echo wp_nonce_url('?page=na-subs-master&delete_sub='.$s->id, 'na_delete_sub_'.$s->id); ?>" style="color:red;">Sil</a></td>
                    </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
            <p><input type="submit" name="bulk_delete_action" class="button action" value="Seçilenleri Sil"></p>
        </form>
    </div>
    <?php
}

