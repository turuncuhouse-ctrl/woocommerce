function na_page_subscribers_master() {
    global $wpdb;
    $table = $wpdb->prefix . 'na_subs_master';
    
    if (isset($_GET['delete_sub'])) {
        $wpdb->delete($table, array('id' => intval($_GET['delete_sub'])));
        echo '<div class="updated"><p>Abone silindi.</p></div>';
    }

    if (isset($_POST['bulk_delete']) && !empty($_POST['sub_ids'])) {
        $ids = array_map('intval', $_POST['sub_ids']);
        $wpdb->query("DELETE FROM $table WHERE id IN (" . implode(',', $ids) . ")");
        echo '<div class="updated"><p>Seçilen aboneler silindi.</p></div>';
    }

    if (isset($_POST['na_import_emails'])) {
        $raw_emails = explode("\n", $_POST['import_data']);
        $list_type = sanitize_text_field($_POST['import_list_type']);
        $added = 0; $skipped = 0;
        foreach($raw_emails as $e) {
            $e = sanitize_email(trim($e));
            if (is_email($e)) {
                $exists = $wpdb->get_var($wpdb->prepare("SELECT id FROM $table WHERE email = %s", $e));
                if (!$exists) {
                    $wpdb->insert($table, array('email' => $e, 'list_type' => $list_type));
                    $added++;
                } else { $skipped++; }
            }
        }
        echo "<div class='updated'><p>✅ $added e-posta eklendi ($skipped adet atlandı).</p></div>";
    }

    if (isset($_POST['na_export'])) {
        ob_end_clean();
        header('Content-Type: text/csv; charset=utf-8');
        header('Content-Disposition: attachment; filename=aboneler.csv');
        $f = fopen('php://output', 'w');
        $rows = $wpdb->get_results("SELECT email, phone, list_type FROM $table", ARRAY_A);
        foreach($rows as $r) fputcsv($f, $r);
        exit;
    }

    $subs = $wpdb->get_results("SELECT * FROM $table ORDER BY id DESC");
    ?>
    <div class="wrap">
        <h1>📢 Abone Yönetimi</h1>
        <div style="display:flex; gap:20px; margin-bottom:20px;">
            <div style="background:#fff; padding:20px; border:1px solid #ccd0d4; flex:2; border-radius:5px;">
