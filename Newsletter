add_action('init', 'na_unsubscribe_master_listener');
function na_unsubscribe_master_listener() {
    if (isset($_GET['na_unsub']) && isset($_GET['t'])) {
        $email = sanitize_email($_GET['na_unsub']);
        if (wp_hash($email) === $_GET['t']) {
            global $wpdb;
            $wpdb->update($wpdb->prefix . 'na_subs_master', array('status' => 'unsubscribed'), array('email' => $email));
            wp_die('Abonelikten ayrıldınız.', 'Başarılı');
        }
    }
}
