        if (wp_hash($email) === $_GET['t']) {
            global $wpdb;
            $wpdb->update($wpdb->prefix . 'na_subs_master', array('status' => 'unsubscribed'), array('email' => $email));
            wp_die('<div style="text-align:center; padding:50px; font-family:sans-serif;"><h2>Abonelikten Ayrıldınız</h2><p><b>'.$email.'</b> adresi listeden silindi.</p></div>', 'Başarılı', array('response' => 200));
        }
    }
}
