                        <select name="import_list_type">
                            <option value="main">Ana Listeye Ekle</option>
                            <option value="test">Test Listesine Ekle</option>
                        </select>
                    </p>
                    <textarea name="import_data" rows="4" style="width:100%; padding:10px;" placeholder="Excel'den e-postaları buraya yapıştırın..."></textarea><br>
                    <button type="submit" name="na_import_emails" class="button button-primary" style="margin-top:10px;">Listeye Ekle</button>
                    <button type="submit" name="na_export" class="button" style="margin-top:10px; margin-left:10px;">Tümünü İndir (CSV)</button>
                </form>
            </div>
        </div>

        <form method="post">
            <div class="alignleft actions">
                <select name="bulk_action"><option value="-1">Toplu İşlemler</option><option value="delete">Sil</option></select>
                <input type="submit" name="bulk_delete" class="button action" value="Uygula" onclick="return confirm('Emin misiniz?');">
