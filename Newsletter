// BÖLÜM 4: GÖNDERİM MOTORU
// =========================================================================
add_action('na_process_mail_action', 'na_domino_processor');
function na_domino_processor() {
    global $wpdb;
    $table = $wpdb->prefix . 'na_queue_master';

    $item = $wpdb->get_row("SELECT * FROM $table WHERE status = 'pending' ORDER BY id ASC LIMIT 1");

    if ($item) {
        $unsub_link = site_url("?na_unsub=" . urlencode($item->target_email) . "&t=" . wp_hash($item->target_email));
        $final_content = str_replace('{UNSUBSCRIBE_LINK}', $unsub_link, $item->content);
        
        if (strpos($final_content, '<div') === false) { $final_content = wpautop($final_content); }

        $headers = array('Content-Type: text/html; charset=UTF-8');
        $success = wp_mail($item->target_email, $item->subject, $final_content, $headers);

        $wpdb->update($table, array('status' => $success ? 'sent' : 'failed'), array('id' => $item->id));

        $remaining = $wpdb->get_var("SELECT COUNT(*) FROM $table WHERE status = 'pending'");
        if ($remaining > 0) {
            $speed = (int)get_option('na_send_interval', 60);
            as_schedule_single_action( time() + $speed, 'na_process_mail_action', array(), 'na_newsletter_group' );
        } else {
            if (!get_option('na_campaign_notified')) {
                wp_mail(get_option('admin_email'), '✅ Kampanya Tamamlandı', 'Toplu mail gönderimi bitti.');
                update_option('na_campaign_notified', 1);
            }
        }
    }
}

