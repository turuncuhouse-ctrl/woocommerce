add_action('wp_loaded', 'na_custom_cache_bypass_cron');
function na_custom_cache_bypass_cron() {
    // cron-job.org buraya vuracak: site.com/?na_cron_tetikle=1
    if (isset($_GET['na_cron_tetikle']) && $_GET['na_cron_tetikle'] == '1') {
        if (!defined('DONOTCACHEPAGE')) define('DONOTCACHEPAGE', true);
        nocache_headers();

        // 1. Motor: WooCommerce Action Scheduler'ı uyanmaya zorla
        if (class_exists('ActionScheduler_QueueRunner')) {
            ActionScheduler_QueueRunner::instance()->run();
        }

        // 2. Motor (Zırhlı Çözüm): WooCommerce uyumakta ısrar ediyorsa, 
        // bizim fonksiyonu manuel olarak 1 kez zorla çalıştır.
        na_domino_processor();

        echo "✅ Çift motorlu tetikleyici calisti. Zaman: " . current_time('mysql');
        exit;
    }
}

