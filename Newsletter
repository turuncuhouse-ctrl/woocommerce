add_action('wp_loaded', 'na_custom_secure_cron_trigger');
function na_custom_secure_cron_trigger() {
    $saved_key = get_option('na_cron_secret_key', 'tb_default_123');

    if (isset($_GET['na_cron_tetikle']) && isset($_GET['key'])) {
        if ($_GET['key'] === $saved_key) {
            if (!defined('DONOTCACHEPAGE')) define('DONOTCACHEPAGE', true);
            nocache_headers();

            if (class_exists('ActionScheduler_QueueRunner')) {
                ActionScheduler_QueueRunner::instance()->run();
            }

            na_domino_processor();
            echo "✅ Yetkili tetikleme basarili. Zaman: " . current_time('mysql');
            exit;
        } else {
            wp_die('Erisim Engellendi: Hatali Guvenlik Anahtari.', '403 Forbidden', array('response' => 403));
        }
    }
}

